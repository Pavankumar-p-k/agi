# .env - JARVIS Hybrid Automation System Configuration
# Copy this to your backend/.env file and fill in your API keys

# ── HYBRID MODEL CONFIGURATION ──
# Claude API (for planning and reasoning)
CLAUDE_API_KEY=your_claude_api_key_here

# GitHub Copilot API (for coding and advanced tasks)
COPILOT_API_KEY=your_copilot_api_key_here
GITHUB_TOKEN=your_github_personal_access_token

# Codex CLI Path (local executable)
CODEX_CLI_PATH=/path/to/codex-cli/executable

# Fallback settings
HYBRID_MAX_RETRIES=3
HYBRID_TIMEOUT_SECONDS=30

# ── OLLAMA MULTI-INSTANCE CONFIGURATION ──
# These should match your Ollama server configurations
OLLAMA_BASE_URL=http://localhost:11434

# Model-specific endpoints (if using multi-instance setup)
OLLAMA_LLAMA3_1_8B_URL=http://localhost:11434
OLLAMA_QWEN2_5_7B_URL=http://localhost:11435
OLLAMA_QWEN2_5_CODER_3B_URL=http://localhost:11436
OLLAMA_QWEN3_4B_URL=http://localhost:11437
OLLAMA_DEEPSEEK_R1_1_5B_URL=http://localhost:11438
OLLAMA_MISTRAL_7B_URL=http://localhost:11439
OLLAMA_PHI3_MINI_URL=http://localhost:11440
OLLAMA_MOONDREAM_URL=http://localhost:11441
OLLAMA_TINYLLAMA_URL=http://localhost:11442

# ── SYSTEM CONFIGURATION ──
HOST=0.0.0.0
PORT=8000
DEV_MODE=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/jarvis.db

# Firebase (for mobile auth)
FIREBASE_CREDENTIALS=./firebase-credentials.json

# Security
SECRET_KEY=your-secret-key-change-in-production

# Logging
LOG_LEVEL=INFO

# Performance tuning
MAX_WORKERS=4
REQUEST_TIMEOUT=30

# Mobile integration
MOBILE_SYNC_ENABLED=true
CROSS_PLATFORM_CONTEXT=true

# Safety settings
EXECUTOR_SAFETY_ENABLED=true
COMMAND_WHITELIST_STRICT=true

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30