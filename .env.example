# === REQUIRED ===
# Server configuration
HOST=0.0.0.0
PORT=8000
SECRET_KEY=generate-a-random-string-here

# Local LLM backend
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# === MODEL CONFIGURATION ===
# Format: 'provider/model-id' or 'provider/model-id @api_base'
# Defaults to local Ollama models if unset
CHAT_MODEL=ollama/qwen3:4b
CODE_MODEL=ollama/qwen2.5-coder:3b
ANALYSIS_MODEL=ollama/qwen2.5:7b
REASONING_MODEL=ollama/deepseek-r1:1.5b
VISION_MODEL=ollama/moondream:latest
EMBEDDING_MODEL=nomic-embed-text
GRADER_MODEL=ollama/phi3:mini

# AIOS agent models
AIOS_PLANNER_MODEL=ollama/qwen3:4b
AIOS_REASONING_MODEL=ollama/deepseek-r1:1.5b
AIOS_FAST_MODEL=ollama/llama3.2:3b

# === CLOUD LLM API KEYS ===
# Uncomment and set to use cloud models
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...
# GEMINI_API_KEY=...
# GROQ_API_KEY=...
# DEEPSEEK_API_KEY=...
# MISTRAL_API_KEY=...
# TOGETHER_API_KEY=...
# FIREWORKS_API_KEY=...
# NVIDIA_API_KEY=...
# XAI_API_KEY=...
# REPLICATE_API_TOKEN=...
# STABILITY_API_KEY=...

# GitHub Copilot / CLI
# GITHUB_TOKEN=ghp_...
# COPILOT_API_KEY=...

# === COMMUNICATION CHANNELS ===
# Discord
# DISCORD_TOKEN=...

# Telegram
# TELEGRAM_BOT_TOKEN=...

# Slack (Socket Mode)
# SLACK_BOT_TOKEN=xapp-...
# SLACK_APP_TOKEN=xapp-...

# IRC
# IRC_SERVER=irc.libera.chat
# IRC_PORT=6667
# IRC_NICK=jarvis-bot
# IRC_CHANNEL=#jarvis
# IRC_PASSWORD=

# Matrix
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_USER_ID=@jarvis:matrix.org
# MATRIX_PASSWORD=...

# WhatsApp Cloud API
# META_WHATSAPP_TOKEN=...
# META_WHATSAPP_PHONE_ID=...
# META_VERIFY_TOKEN=...

# Email (IMAP/SMTP)
# EMAIL_HOST=imap.gmail.com
# EMAIL_PORT=993
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=app-password-here
# EMAIL_USE_SSL=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465

# === EXTERNAL SERVICES ===
# Search
# SEARXNG_URL=http://localhost:4000
# TAVILY_API_KEY=tvly-...
# BRAVE_API_KEY=...

# APIs
# NEWS_API_KEY=...
# OPENWEATHER_API_KEY=...
# ALPHA_VANTAGE_KEY=...
# PEXELS_API_KEY=...

# Supabase (optional cloud sync)
# SUPABASE_URL=https://...
# SUPABASE_SERVICE_KEY=...
# SUPABASE_ANON_KEY=...

# Composio (tool integrations)
# COMPOSIO_API_KEY=...

# RAGFlow
# RAGFLOW_BASE_URL=http://localhost:9380
# RAGFLOW_API_KEY=...

# === DOCKER SANDBOX ===
DOCKER_SANDBOX_NETWORK=false
DOCKER_SANDBOX_TIMEOUT=30
DOCKER_SANDBOX_MEMORY=256m

# === VOICE / SPEECH ===
WAKE_WORD_ENABLED=false
STT_MODEL=base
TTS_VOICE=af_heart

# === OAUTH ===
# For web-based authentication
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# DISCORD_CLIENT_ID=...
# DISCORD_CLIENT_SECRET=...

# === DATABASE ===
# Uses SQLite by default. For PostgreSQL:
# JARVIS_DB__URL=postgresql+asyncpg://user:pass@localhost/jarvis

# === LOGGING ===
LOG_LEVEL=INFO
# JARVIS_DEV_MODE=true

# === CHROMA VECTOR DB ===
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8100

# === MCP ===
# MCP_BRIDGE_TOKEN=...
