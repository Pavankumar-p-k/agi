# === Required ===
HOST=0.0.0.0
PORT=8000
OLLAMA_URL=http://localhost:11434
SECRET_KEY=generate-a-random-string-here

# === Model Configuration (Optional, defaults to local Ollama) ===
# Format: 'provider/model-id' or 'provider/model-id @api_base'
# CHAT_MODEL=ollama/llama3.1:8b
# CODE_MODEL=ollama/qwen2.5-coder:3b
# ANALYSIS_MODEL=ollama/qwen2.5:7b
# REASONING_MODEL=ollama/deepseek-r1:1.5b
# VISION_MODEL=ollama/moondream:latest
# GRADER_MODEL=ollama/phi3:mini

# === Optional Cloud LLMs (uncomment to enable) ===
# ANTHROPIC_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# GROQ_API_KEY=...

# === Optional Features ===
# SUPABASE_URL=https://...
# SUPABASE_SERVICE_KEY=...
# TELEGRAM_BOT_TOKEN=...
